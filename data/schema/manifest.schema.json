{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ohpcsim/aicr-binder-dashboards/data/schema/manifest.schema.json",
  "title": "AICR Binder Dashboard Manifest",
  "type": "object",
  "required": ["schema_version", "generated_at", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "generated_at": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "module",
          "study",
          "cluster",
          "date",
          "role",
          "evidence_type",
          "artifact_type",
          "format",
          "url",
          "public_page"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$"},
          "title": {"type": "string"},
          "module": {"type": "string"},
          "study": {"type": "string"},
          "cluster": {"type": "string"},
          "date": {"type": "string"},
          "role": {"type": "string", "enum": ["campaign", "canonical", "supporting", "appendix", "diagnostic", "planned"]},
          "evidence_type": {"type": "string"},
          "artifact_type": {"type": "string"},
          "format": {"type": "string", "enum": ["csv", "json", "markdown", "tar.gz", "sha256", "other"]},
          "url": {"type": "string", "format": "uri"},
          "public_page": {"type": "string", "format": "uri"},
          "provenance_url": {"type": "string"},
          "checksum_url": {"type": "string"},
          "bundle_url": {"type": "string"},
          "local_path": {"type": "string"},
          "source_page": {"type": "string"},
          "source_table": {"type": "integer", "minimum": 1},
          "source_kind": {"type": "string"},
          "commit": {"type": "string"},
          "notes": {"type": "string"},
          "metrics": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    }
  }
}
